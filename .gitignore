# ══════════════════════════════════════
#  Oralytics AI — .gitignore
#  Industry Level | MERN Stack
# ══════════════════════════════════════

# ── Dependencies ──
node_modules/
**/node_modules/
.pnp
.pnp.js

# ── Environment Variables ──
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
**/.env
**/.env.local
**/.env.production

# ── Build Outputs ──
dist/
build/
out/
.next/
.nuxt/
**/dist/
**/build/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
**/logs/
**/*.log

# ── OS Files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
**/.DS_Store

# ── Editor / IDE ──
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ── User Uploads / Media ──
server/public/resumes/
server/public/uploads/
server/public/temp/
uploads/
**/uploads/

# ── Testing & Coverage ──
coverage/
.nyc_output/
*.lcov
**/__snapshots__/

# ── Cache ──
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.vite/
**/.cache/

# ── Package Manager Locks ──
# (uncomment if solo project)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ── Security ──
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
.secrets

# ── Deployment ──
.vercel
.netlify
.turbo
.railway
.render

# ── Misc ──
*.tmp
*.temp
*.bak
*.orig
*.patch
.history/